# ============================================
# DisherIo Caddyfile - Modo PUBLIC-IP
# ============================================
# IP pública con túnel (Cloudflare Tunnel / ngrok)
# El túnel maneja el HTTPS externamente
# Caddy escucha en puerto interno sin TLS
# ============================================

{
    admin off
    auto_https off
    http_port ${CADDY_INTERNAL_PORT}
}

# Servidor HTTP interno (el túnel se conecta aquí)
:${CADDY_INTERNAL_PORT} {
    bind 0.0.0.0

    # Headers de seguridad
    # Nota: El túnel añadirá headers adicionales de seguridad
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: blob: https://api.qrserver.com; connect-src 'self' wss://{http.request.host}; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "0"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
        -Server
    }

    # Compresión
    encode gzip zstd

    # Servir archivos subidos
    handle /uploads/* {
        root * /srv
        file_server
        header Content-Security-Policy "default-src 'none'; img-src 'self'"
    }

    @health path /health /health/*
    handle @health {
        reverse_proxy backend:3000 {
            header_up X-Forwarded-Proto https
            header_up X-Forwarded-Host {host}
        }
    }

    # Reverse proxy a backend API
    handle /api/* {
        reverse_proxy backend:3000 {
            # TLS terminates at the public tunnel. Preserve the browser-facing
            # scheme so the backend always marks authentication cookies Secure.
            header_up X-Forwarded-Proto https
            header_up X-Forwarded-Host {host}
        }
    }

    # Reverse proxy a Socket.IO (WebSockets)
    handle /socket.io/* {
        reverse_proxy backend:3000 {
            flush_interval -1
            header_up X-Forwarded-Proto https
            header_up X-Forwarded-Host {host}
            transport http {
                versions 1.1
            }
        }
    }

    # Reverse proxy al frontend
    handle {
        reverse_proxy frontend:4200
    }
}
