# ============================================
# DisherIo Environment Configuration
# Copy this file to .env and update the values
# ============================================

# ============================================
# Application Settings
# ============================================
NODE_ENV=production
PORT=80
HTTPS_PORT=443

# ============================================
# Security (REQUIRED - CHANGE THESE!)
# ============================================
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=change-this-to-a-secure-random-string-min-32-characters
JWT_EXPIRES=8h

# ============================================
# Database (REQUIRED - CHANGE THESE!)
# ============================================
# MongoDB Root User (admin privileges - keep secure!)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=change-this-to-a-secure-password

# MongoDB Application User (limited readWrite privileges)
# This user is used by the backend application
MONGO_APP_USER=disherio_app
MONGO_APP_PASS=change-this-app-password

# MongoDB Connection URI (auto-generated from above if not set)
# Format: mongodb://username:password@host:port/database?authSource=database
# MONGODB_URI=mongodb://disherio_app:change-this-app-password@mongo:27017/disherio?authSource=disherio

# MongoDB Connection Pool Settings (optional)
# MONGODB_MAX_POOL_SIZE=50
# MONGODB_SERVER_SELECTION_TIMEOUT=30000
# MONGODB_SOCKET_TIMEOUT=45000

# ============================================
# Frontend Configuration
# ============================================
FRONTEND_URL=http://localhost

# ============================================
# Logging
# ============================================
# Options: debug, info, warn, error
LOG_LEVEL=info

# ============================================
# Optional: Email Configuration (for notifications)
# ============================================
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@disherio.com

# ============================================
# Optional: Cloud Storage (for uploads)
# ============================================
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ============================================
# Optional: Monitoring
# ============================================
# SENTRY_DSN=
# LOGGLY_TOKEN=

# ============================================
# Development Only (do not use in production)
# ============================================
# DEBUG=true
# MOCK_DATA=false
