# =============================================================================
# DisherIo - Ejemplo de Configuracion de Entorno
# =============================================================================
# Este archivo proporciona un ejemplo completo de todas las variables de
# configuracion disponibles. Para generar un archivo .env funcional, ejecute:
#   ./infrastructure/scripts/configure.sh
#
# ADVERTENCIA: No utilice estos valores en produccion. Las contraseñas deben
# ser generadas aleatoriamente y almacenadas de forma segura.
# =============================================================================

# =============================================================================
# SECCION 1: MODO DE DESPLIEGUE
# =============================================================================
# Determina la configuracion global del sistema.
# Valores validos: local | local-ip | public-ip | domain
DEPLOYMENT_MODE=local

# =============================================================================
# SECCION 2: CONFIGURACION DE RED Y URLs
# =============================================================================

# -----------------------------------------------------------------------------
# Configuracion General
# -----------------------------------------------------------------------------
# Puerto del servicio backend (API)
PORT=3000

# Puerto HTTP para el servidor web (Caddy)
HTTP_PORT=80

# Puerto HTTPS para el servidor web (Caddy)
HTTPS_PORT=443

# URLs de acceso
FRONTEND_URL=http://localhost:4200
BACKEND_URL=http://localhost:3000/api

# -----------------------------------------------------------------------------
# Configuracion Especifica: Modo Local
# -----------------------------------------------------------------------------
# Puerto alternativo para desarrollo local (evita conflictos con otros servicios)
CADDY_PORT=4200

# -----------------------------------------------------------------------------
# Configuracion Especifica: Modo Red Local
# -----------------------------------------------------------------------------
# Direccion IP de la maquina en la red local (ej: 192.168.1.100)
# Usar: hostname -I (Linux) o ipconfig getifaddr en0 (macOS)
LOCAL_IP=192.168.1.100

# -----------------------------------------------------------------------------
# Configuracion Especifica: Modo IP Publica
# -----------------------------------------------------------------------------
# Direccion IP publica del servidor
# Usar: curl ifconfig.me
PUBLIC_IP=0.0.0.0

# Puerto interno para comunicacion con el tunel (no expuesto externamente)
CADDY_INTERNAL_PORT=8080

# Tipo de tunel para HTTPS
# Valores validos: cloudflare | ngrok
TUNNEL_TYPE=cloudflare

# URL asignada por el servicio de tunel
TUNNEL_URL=https://ejemplo.cloudflare-access.com

# Token de Cloudflare Tunnel (obtenido del dashboard de Cloudflare)
CF_TUNNEL_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Dominio asignado por Cloudflare
CF_TUNNEL_DOMAIN=tunel-uuid.cfargotunnel.com

# Token de autenticacion de ngrok (obtenido de dashboard.ngrok.com)
NGROK_AUTHTOKEN=2abc123def456...

# -----------------------------------------------------------------------------
# Configuracion Especifica: Modo Dominio Propio
# -----------------------------------------------------------------------------
# Nombre de dominio completo (FQDN)
DOMAIN=disherio.ejemplo.com

# Correo electronico para notificaciones de Let's Encrypt
EMAIL=admin@ejemplo.com

# Habilitar TLS automatico
TLS_ENABLED=true
TLS_AUTO=true

# =============================================================================
# SECCION 3: SEGURIDAD Y AUTENTICACION
# =============================================================================

# -----------------------------------------------------------------------------
# JSON Web Tokens (JWT)
# -----------------------------------------------------------------------------
# Clave secreta para firma de tokens JWT
# Generar con: openssl rand -hex 32
# Requisitos: Minimo 32 caracteres, alta entropia
JWT_SECRET=cambiar_esto_por_un_secreto_largo_y_aleatorio_de_al_menos_64_caracteres

# Tiempo de expiracion de tokens
# Formatos validos: 60s, 5m, 8h, 1d, 7d
JWT_EXPIRES=8h

# -----------------------------------------------------------------------------
# Base de Datos MongoDB
# -----------------------------------------------------------------------------
# URI de conexion completa
# Formato: mongodb://[usuario]:[password]@[host]:[puerto]/[database]?[opciones]
MONGODB_URI=mongodb://disherio_app:password_seguro@mongo:27017/disherio?authSource=disherio

# Credenciales de usuario root (administracion)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=cambiar_esta_contrasena_root_inmediatamente

# Credenciales de usuario de aplicacion
MONGO_APP_USER=disherio_app
MONGO_APP_PASS=cambiar_esta_contrasena_app_inmediatamente

# -----------------------------------------------------------------------------
# Cache Redis
# -----------------------------------------------------------------------------
# URI de conexion
REDIS_URL=redis://redis:6379

# Contrasena de autenticacion
# Generar con: openssl rand -base64 32
REDIS_PASSWORD=cambiar_esta_contrasena_redis_inmediatamente

# =============================================================================
# SECCION 4: BASE DE DATOS - PARAMETROS AVANZADOS
# =============================================================================

# Tamano maximo del pool de conexiones
MONGODB_MAX_POOL_SIZE=50

# Tiempo de espera para seleccion de servidor (milisegundos)
MONGODB_SERVER_SELECTION_TIMEOUT=30000

# Tiempo de espera para operaciones de socket (milisegundos)
MONGODB_SOCKET_TIMEOUT=45000

# =============================================================================
# SECCION 5: LOGGING Y MONITOREO
# =============================================================================

# Nivel de detalle de logs
# Valores validos: debug | info | warn | error
LOG_LEVEL=info

# Habilitar logs de acceso HTTP (Caddy)
# Valores: true | false
ACCESS_LOGS=false

# Formato de logs
# Valores: json | console
LOG_FORMAT=console

# =============================================================================
# SECCION 6: MONITOREO (OPCIONAL)
# =============================================================================

# Credenciales de administrador de Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=cambiar_contrasena_grafana

# Habilitar exportadores de metricas
# Valores: true | false
ENABLE_METRICS=true

# =============================================================================
# SECCION 7: CONFIGURACIONES ESPECIFICAS DEL MODO
# =============================================================================

# Modo local: Habilitar hot-reload para desarrollo
NODE_ENV=production

# Modo produccion: Habilitar confianza en proxy
TRUST_PROXY=false

# =============================================================================
# SECCION 8: VARIABLES INTERNAS (NO MODIFICAR)
# =============================================================================
# Estas variables son gestionadas automaticamente por el sistema.
# Modificarlas manualmente puede causar fallos en el despliegue.

# VERSION=1.0.0
# BUILD_DATE=2024-01-15
# CONFIG_HASH=abc123

# =============================================================================
# NOTAS DE SEGURIDAD
# =============================================================================
#
# 1. NUNCA comitee el archivo .env al control de versiones.
#    Este archivo debe estar en .gitignore
#
# 2. NUNCA reutilice contraseñas entre diferentes servicios.
#
# 3. Las contraseñas deben:
#    - Tener al menos 16 caracteres
#    - Incluir mayusculas, minusculas, numeros y simbolos
#    - No contener palabras del diccionario
#    - Ser unicas para cada instalacion
#
# 4. El JWT_SECRET debe:
#    - Tener al menos 32 bytes de entropia
#    - Rotarse periodicamente (recomendado: cada 90 dias)
#    - Almacenarse en un gestor de secretos en produccion
#
# 5. Para entornos de produccion, considere:
#    - Usar un gestor de secretos (HashiCorp Vault, AWS Secrets Manager)
#    - Habilitar encriptacion de volumenes de Docker
#    - Implementar rotacion automatica de credenciales
#
# =============================================================================
