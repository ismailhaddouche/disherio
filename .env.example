# =============================================================================
# DisherIo - Environment Configuration Example
# =============================================================================
# This file provides a complete example of every available configuration
# variable. To generate a working .env file, run:
#   ./infrastructure/scripts/configure.sh
#
# WARNING: Do not use these values in production. Passwords must be generated
# randomly and stored securely.
# =============================================================================

# =============================================================================
# SECTION 1: DEPLOYMENT MODE
# =============================================================================
# Determines the global system configuration.
# Valid values: local | local-ip | public-ip | domain
DEPLOYMENT_MODE=local

# =============================================================================
# SECTION 2: NETWORK CONFIGURATION AND URLs
# =============================================================================

# -----------------------------------------------------------------------------
# General Configuration
# -----------------------------------------------------------------------------
# Backend service port (API)
PORT=3000

# Web server HTTP port (Caddy)
HTTP_PORT=80

# Web server HTTPS port (Caddy)
HTTPS_PORT=443

# Access URL
FRONTEND_URL=http://localhost:4200

# -----------------------------------------------------------------------------
# Mode-Specific Configuration: Local
# -----------------------------------------------------------------------------
# Alternative local development port (avoids conflicts with other services)
CADDY_PORT=4200

# -----------------------------------------------------------------------------
# Mode-Specific Configuration: Local Network
# -----------------------------------------------------------------------------
# Machine IP address on the local network (for example, 192.168.1.100)
# Use: hostname -I (Linux) or ipconfig getifaddr en0 (macOS)
LOCAL_IP=192.168.1.100

# -----------------------------------------------------------------------------
# Mode-Specific Configuration: Public IP
# -----------------------------------------------------------------------------
# Internal tunnel communication port (not exposed externally)
CADDY_INTERNAL_PORT=8080

# HTTPS tunnel type
# Valid values: cloudflare | ngrok
TUNNEL_TYPE=cloudflare

# URL assigned by the tunnel service
TUNNEL_URL=https://ejemplo.cloudflare-access.com

# Cloudflare Tunnel token (obtained from the Cloudflare dashboard)
CF_TUNNEL_TOKEN=

# Domain assigned by Cloudflare
CF_TUNNEL_DOMAIN=tunel-uuid.cfargotunnel.com

# ngrok authentication token (obtained from dashboard.ngrok.com)
NGROK_AUTHTOKEN=

# Reserved ngrok HTTPS domain (for example, app.ngrok.app)
# Required when TUNNEL_TYPE=ngrok
NGROK_DOMAIN=app.ngrok.app

# -----------------------------------------------------------------------------
# Mode-Specific Configuration: Custom Domain
# -----------------------------------------------------------------------------
# Fully qualified domain name (FQDN)
DOMAIN=disherio.ejemplo.com

# Email address for Let's Encrypt notifications
EMAIL=admin@ejemplo.com

# =============================================================================
# SECTION 3: SECURITY AND AUTHENTICATION
# =============================================================================

# -----------------------------------------------------------------------------
# JSON Web Tokens (JWT)
# -----------------------------------------------------------------------------
# Secret key for signing access JWTs
# Generate with: openssl rand -hex 32
# Requirements: at least 32 characters and high entropy
JWT_SECRET=

# Access token lifetime
# Valid formats: 60s, 5m, 8h, 1d, 7d
JWT_EXPIRES=15m

# Secret key for signing refresh tokens
# Generate with: openssl rand -hex 32
# Requirements: at least 32 characters, high entropy, and different from JWT_SECRET
JWT_REFRESH_SECRET=

# Refresh token lifetime
# Valid formats: 60s, 5m, 8h, 1d, 7d
JWT_REFRESH_EXPIRES=7d

# bcrypt cost factor (password hashing)
# Valid range: 10-15 (higher is safer but slower)
BCRYPT_ROUNDS=12

# Token for internal service-to-service endpoints (for example, /metrics).
# When set, internal requests must send it in the x-internal-token header.
# Generate with: openssl rand -hex 32
# INTERNAL_API_TOKEN=

# -----------------------------------------------------------------------------
# MongoDB Database
# -----------------------------------------------------------------------------
# Full connection URI
# Format: mongodb://[user]:[password]@[host]:[port]/[database]?[options]
# Note: replicaSet=rs0 is required to support MongoDB transactions.
MONGODB_URI=

# Root user credentials (administration)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=

# Application user credentials
MONGO_APP_USER=disherio_app
MONGO_APP_PASS=

# -----------------------------------------------------------------------------
# Cache Redis
# -----------------------------------------------------------------------------
# Connection URI
REDIS_URL=redis://redis:6379

# Authentication password
# Generate with: openssl rand -base64 32
REDIS_PASSWORD=

# =============================================================================
# SECTION 4: DATABASE - ADVANCED PARAMETERS
# =============================================================================

# Maximum connection pool size
MONGODB_MAX_POOL_SIZE=50

# Server selection timeout (milliseconds)
MONGODB_SERVER_SELECTION_TIMEOUT=30000

# Socket operation timeout (milliseconds)
MONGODB_SOCKET_TIMEOUT=45000

# =============================================================================
# SECTION 5: LOGGING AND MONITORING
# =============================================================================

# Log detail level
# Valid values: debug | info | warn | error
LOG_LEVEL=info

# =============================================================================
# SECTION 6: MODE-SPECIFIC SETTINGS
# =============================================================================

# Local mode: development. Production: production.
NODE_ENV=development

# Production mode: trust the reverse proxy (Caddy/Nginx/Cloudflare)
TRUST_PROXY=true

# Development only: disable HTTP rate limiting when NODE_ENV=development.
# Never set this in production.
# DISABLE_RATE_LIMIT=false

# =============================================================================
# SECTION 7: INITIAL DATA (SEED) AND APPLICATION
# =============================================================================
# These variables are used when seeding the database (the `seed` service in
# docker-compose.yml) and during initial application configuration.

# -----------------------------------------------------------------------------
# Initial Administrator User
# -----------------------------------------------------------------------------
# Initial administrator username
ADMIN_USERNAME=admin

# Initial administrator password. The seed fails when it is not defined.
# Docker Compose mounts it as a Docker secret (config/secrets/admin_password,
# ADMIN_PASSWORD_FILE) instead of exposing it in the container environment.
ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# Example data (optional)
# -----------------------------------------------------------------------------
# The seed-examples service creates demo categories, dishes and staff users
# with well-known credentials. In production it refuses to run unless this
# explicit confirmation is set to "true".
SEED_EXAMPLES_CONFIRM=false

# -----------------------------------------------------------------------------
# Restaurant and Interface
# -----------------------------------------------------------------------------
# Restaurant name displayed in the application
RESTAURANT_NAME=DisherIo

# Default system language
# Valid values: es | en | fr
DEFAULT_LANGUAGE=es

# Compatibility language alias; the seed only uses it when DEFAULT_LANGUAGE
# is not defined
APP_LANG=es

# Default currency (for example, EUR, USD, GBP)
DEFAULT_CURRENCY=EUR

# Default tax rate (percentage)
DEFAULT_TAX_RATE=10

# Initial interface theme
# Valid values: light | dark
DEFAULT_THEME=light

# -----------------------------------------------------------------------------
# Image Storage
# -----------------------------------------------------------------------------
# Directory where the backend stores processed images (WebP)
# In Docker, the disherio_uploads volume is mounted at /app/uploads
UPLOADS_DIR=/app/uploads

# =============================================================================
# SECTION 8: INTERNAL VARIABLES (DO NOT MODIFY)
# =============================================================================
# These variables are managed automatically by the system.
# Modifying them manually may cause deployment failures.

# VERSION=1.0.0
# BUILD_DATE=2024-01-15
# CONFIG_HASH=abc123

# =============================================================================
# SECURITY NOTES
# =============================================================================
#
# 1. NEVER commit the .env file to version control.
#    This file must remain in .gitignore.
#
# 2. NEVER reuse passwords across different services.
#
# 3. Passwords must:
#    - Contain at least 16 characters
#    - Include uppercase letters, lowercase letters, numbers, and symbols
#    - Not contain dictionary words
#    - Be unique to each installation
#
# 4. JWT_SECRET must:
#    - Contain at least 32 bytes of entropy
#    - Be rotated periodically (recommended: every 90 days)
#    - Be stored in a secret manager in production
#
# 5. For production environments, consider:
#    - Using a secret manager (HashiCorp Vault, AWS Secrets Manager)
#    - Enabling Docker volume encryption
#    - Implementing automatic credential rotation
#
# =============================================================================
