{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**",
          "/media/**/*.(png|jpg|jpeg|svg|gif|webp)",
          "/icons/**"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "menu-api",
      "urls": ["/api/dishes/**", "/api/categories/**"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 100,
        "maxAge": "1d",
        "timeout": "5s"
      }
    },
    {
      "name": "config-api",
      "urls": ["/api/restaurant/config"],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 10,
        "maxAge": "1h"
      }
    },
    {
      "name": "user-api",
      "urls": ["/api/auth/me", "/api/users/profile"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 10,
        "maxAge": "30m",
        "timeout": "3s"
      }
    }
  ]
}
