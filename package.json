{
  "name": "disherio",
  "version": "1.0.0",
  "description": "DisherIo Restaurant Management System",
  "private": true,
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "build:shared": "npm run build --workspace=shared",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run start --workspace=frontend",
    "build": "npm run build --workspace=shared && npm run build --workspace=backend && npm run build --workspace=frontend",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "eslint backend/src shared --max-warnings=0",
    "lint:frontend": "eslint frontend/src --max-warnings=0",
    "docs:check": "node infrastructure/tests/validate-documentation.mjs",
    "system:install": "bash scripts/install.sh install",
    "start": "bash scripts/install.sh start",
    "stop": "bash scripts/install.sh stop",
    "restart": "bash scripts/install.sh restart",
    "status": "bash scripts/install.sh status",
    "logs": "bash scripts/install.sh logs",
    "backup": "bash scripts/install.sh backup"
  },
  "keywords": [],
  "author": "Ismail Haddouche Rhali",
  "license": "AGPL-3.0-only",
  "devDependencies": {
    "@angular/animations": "21.2.18",
    "@angular/common": "21.2.18",
    "@angular/compiler": "21.2.18",
    "@angular/core": "21.2.18",
    "@angular/forms": "21.2.18",
    "@angular/platform-browser": "21.2.18",
    "@angular/router": "21.2.18",
    "@angular/service-worker": "21.2.18",
    "@eslint/js": "^9.39.5",
    "angular-eslint": "^21.4.0",
    "eslint": "^9.39.5",
    "globals": "^16.5.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.65.0"
  },
  "overrides": {
    "@angular/animations": "21.2.18",
    "@angular/common": "21.2.18",
    "@angular/compiler": "21.2.18",
    "@angular/core": "21.2.18",
    "@angular/forms": "21.2.18",
    "@angular/platform-browser": "21.2.18",
    "@angular/router": "21.2.18",
    "@angular/service-worker": "21.2.18"
  }
}
